[user]
	name = Scott Feinstein
	email = Scott_Feinstein@yahoo.com
	signingkey = {{ .chezmoi.homeDir }}/.ssh/{{ .gitSigningKey }}.pub
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
[init]
	defaultBranch = main
{{- if eq .chezmoi.os "windows" }}
[core]
	sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- end }}
